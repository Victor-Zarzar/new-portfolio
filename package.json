{
  "name": "my-portfolio",
  "version": "1.4.0",
  "private": true,
  "author": "victorzarzar (https://github.com/Victor-Zarzar)",
  "repository": "https://github.com/Victor-Zarzar/my-portfolio",
  "bugs": {
    "url": "https://github.com/Victor-Zarzar/my-portfolio/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typegen": "next typegen",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test tests/units",
    "test:watch": "bun test tests/units --watch",
    "test:update": "bun test tests/units --update-snapshots",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "prod": "bun run build && bun run start",
    "clean": "rm -rf node_modules .next playwright-report test-results",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "redis-start": "redis-server",
    "redis:monitor": "redis-cli monitor",
    "update-deps": "bun update",
    "update-latest": "bun update --latest"
  },
